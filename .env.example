# Secure Storage Secret Key
# Set this to a unique random string for encrypting client-side storage
# In Dokploy, add this as an environment variable with your secret value
# Example: VITE_SECRET_KEY=your_unique_random_string_here_at_least_16_chars
VITE_SECRET_KEY=

# Client URL for CORS
# Comma-separated list of allowed origins
CLIENT_URL=http://localhost:5173

# LLM API Configuration
# The API key is baked into the client bundle at build time
VITE_LLM_API_KEY=your_api_key_here
VITE_LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
VITE_LLM_MODEL=gemini-flash-latest
