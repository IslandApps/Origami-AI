# Client URL for CORS
# Comma-separated list of allowed origins
CLIENT_URL=http://localhost:5173

# LLM API Configuration
# For local development you can keep a VITE-prefixed key which Vite will expose to the dev client.
# Do NOT set a VITE-prefixed key in production. Instead set the server-only key below so it is NOT baked
# into the client bundle. In production set `LLM_API_KEY` in your host/secret manager and do NOT include
# it in the client build environment.
VITE_LLM_API_KEY=your_api_key_here
VITE_LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
VITE_LLM_MODEL=gemini-flash-latest

# Server-side LLM key (use this for production; do NOT prefix with VITE_)
LLM_API_KEY=
